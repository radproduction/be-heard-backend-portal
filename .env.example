# ============================================
# BeHeard Backend - Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=production

# Public URL of THIS backend (used for Meta OAuth callbacks)
APP_URL=https://your-backend.up.railway.app

# URL of the frontend (used for CORS). Use * to allow all during testing.
CLIENT_URL=https://your-frontend.vercel.app

# MongoDB Atlas connection string
# Create a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/beheard?retryWrites=true&w=majority

# Auth - use a long random string in production (e.g. `openssl rand -base64 32`)
JWT_SECRET=change-this-to-a-long-random-secret

# AI APIs
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Meta (Facebook/Instagram) - optional, only for publishing/analytics
META_APP_ID=
META_APP_SECRET=
